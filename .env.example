# NetMeter Configuration (12-factor)
# Copy to .env and adjust as needed.

# Measurement interval in seconds (default: 600 = 10 minutes)
NETMETER_INTERVAL=600

# Number of retry attempts on speed test failure (default: 3)
NETMETER_RETRIES=3

# Delay in seconds between retries (default: 15)
NETMETER_RETRY_DELAY=15

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
NETMETER_LOG_LEVEL=INFO

# Override auto-detected network name (useful in Docker / headless)
# NETMETER_NETWORK_NAME=MyNetwork

# Database directory (default: ./data)
# NETMETER_DB_DIR=/path/to/data

# Database filename (default: speedtest.db)
# NETMETER_DB_NAME=speedtest.db

# Output directory for dashboard HTML and graphs (default: ./output)
# NETMETER_OUTPUT_DIR=/path/to/output

# Graph DPI for PNG export (default: 120)
# NETMETER_GRAPH_DPI=120

# Dashboard HTTP server port (0 = disabled, default in Docker: 9280)
# NETMETER_DASHBOARD_PORT=0

# Dashboard HTTP server bind address (default: 0.0.0.0)
# NETMETER_DASHBOARD_HOST=0.0.0.0
